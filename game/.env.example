# game/.env.example
# ─────────────────────────────────────────────────────────────
# Copy this file to game/.env and fill in your real API key.
#
#   cp game/.env.example game/.env
#
# Then open game/.env and replace the placeholder below.
# The game will load it automatically on startup.
#
# Get your key at: https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your-api-key-here
